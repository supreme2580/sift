{
  "name": "@supreme2580/zkauth",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./circuit.json": "./dist/circuit.json"
  },
  "files": [
    "dist/",
    "circuits/"
  ],
  "scripts": {
    "build": "tsc && cp circuits/identity.json dist/circuit.json",
    "compile-circuit": "cd circuits/identity && nargo compile --force && cp target/zkpay.json ../identity.json",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@aztec/bb.js": "^4.4.0",
    "@noir-lang/noir_js": "1.0.0-beta.9",
    "@stellar/stellar-sdk": "^16.0.1",
    "react": "^19"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19",
    "typescript": "^5"
  }
}
