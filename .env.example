# === Stellar Network ===
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_FEE=100000
HORIZON_URL=https://horizon-testnet.stellar.org

# === Admin Account ===
# Generate with: stellar keys generate admin --no-fund
# Fund with: curl "https://friendbot.stellar.org?addr=<PUBLIC_KEY>"
ADMIN_SECRET_KEY=
ADMIN_PUBLIC_KEY=

# === zkGate Contract ===
# Set after deploying: stellar contract deploy --alias zkgate ...
ZKGATE_CONTRACT_ID=

# === Privy (Wallet Connection) ===
# Sign up at https://privy.io to get an app ID
PRIVY_APP_ID=

# === Frontend (Vite) ===
# These are prefixed with VITE_ so Vite exposes them to the browser
VITE_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
VITE_STELLAR_NETWORK=TESTNET
VITE_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
VITE_HORIZON_URL=https://horizon-testnet.stellar.org
VITE_CONTRACT_ID=
VITE_PRIVY_APP_ID=

# === API Server ===
# API port (default: 3001)
API_PORT=3001

# === Frontend API Client (Vite) ===
# URL of the zkGate API server
VITE_API_URL=http://localhost:3001/api
# Admin token for API auth (use ADMIN_SECRET_KEY value)
VITE_ADMIN_API_TOKEN=
